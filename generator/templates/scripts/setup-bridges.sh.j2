#!/bin/bash
# NetWatch — Bridge Setup
# Generated from topology.yml — DO NOT HAND-EDIT
#
# Creates all fabric bridges (52 P2P + 1 management).
# All fabric bridges have STP disabled (L3 routing, not L2 switching).
#
# Run as root: sudo ./setup-bridges.sh

set -euo pipefail

echo "NetWatch: Creating fabric bridges..."

# --- Management bridge ---
echo "  [mgmt] {{ mgmt_bridge }}"
ip link add {{ mgmt_bridge }} type bridge 2>/dev/null || true
ip link set {{ mgmt_bridge }} up
ip addr add {{ mgmt_gateway }}/24 dev {{ mgmt_bridge }} 2>/dev/null || true
# STP off on management bridge too
echo 0 > /sys/class/net/{{ mgmt_bridge }}/bridge/stp_state 2>/dev/null || true

# --- Fabric bridges (STP disabled, no IP) ---
{% for link in links %}
echo "  [{{ link.tier }}] {{ link.bridge }} ({{ link.a_name }} <-> {{ link.b_name }})"
ip link add {{ link.bridge }} type bridge 2>/dev/null || true
echo 0 > /sys/class/net/{{ link.bridge }}/bridge/stp_state
ip link set {{ link.bridge }} up
{% endfor %}

echo ""
echo "NetWatch: {{ links|length }} fabric bridges + 1 mgmt bridge created."
echo "  Total: {{ links|length + 1 }} bridges, all STP disabled."
