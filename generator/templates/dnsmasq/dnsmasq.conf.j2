# NetWatch — dnsmasq configuration
# Generated from topology.yml — DO NOT HAND-EDIT
#
# Authoritative DNS server for the OOB management network.
# Resolves hostname.netwatch.lab → management IP for all 30 nodes.
# DHCP is handled by libvirt on the host — dnsmasq is DNS-only.

# --- General ---
domain={{ domain }}
local=/{{ domain }}/
expand-hosts
no-resolv
bogus-priv

# --- DNS only (DHCP handled by libvirt on the host) ---
port=53

# --- DNS entries (hostname → management IP) ---
{% for res in reservations %}
address=/{{ res.name }}.{{ domain }}/{{ res.ip }}
{% endfor %}

# --- Logging ---
log-queries
