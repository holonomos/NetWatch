# NetWatch — Pinned artifact versions
# All binary artifacts and their versions for reproducible builds.
# Sourced by scripts/repo/build-repo.sh

# Host metrics exporter (installed on all 18 VMs)
NODE_EXPORTER_VERSION="1.7.0"

# FRR metrics exporter (bind-mounted into FRR containers)
# Repo: github.com/tynany/frr_exporter (formerly tynovsky)
FRR_EXPORTER_VERSION="1.10.1"

# Log pipeline (installed on mgmt VM)
PROMTAIL_VERSION="2.9.3"
LOKI_VERSION="2.9.3"

# Monitoring (installed on mgmt VM)
PROMETHEUS_VERSION="2.47.0"

# Dashboards (installed on mgmt VM)
GRAFANA_VERSION="10.0.3"
GRAFANA_RPM_RELEASE="1"

# Container runtime / orchestration (binary-only install, no auto-start)
K3S_VERSION="v1.31.4+k3s1"

# FRR container image
FRR_IMAGE="quay.io/frrouting/frr:9.1.0"

# Guest OS (VMs) — must match the vagrant box
FEDORA_RELEASE="43"
